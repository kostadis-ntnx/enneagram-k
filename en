#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_TARGET_ROOT="/Users/kostadis.roussos/Documents/CampaignGenerator"
TARGET_ROOT="${ENNEGRAM_TARGET_ROOT:-$DEFAULT_TARGET_ROOT}"
CLI_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      if [[ $# -lt 2 ]]; then
        echo "error: --target requires a path argument" >&2
        exit 2
      fi
      TARGET_ROOT="$2"
      shift 2
      ;;
    --target=*)
      TARGET_ROOT="${1#*=}"
      shift
      ;;
    *)
      CLI_ARGS+=("$1")
      shift
      ;;
  esac
done

ENNEGRAM_TARGET_ROOT="$TARGET_ROOT" python3 "$SCRIPT_DIR/ennegram_cli.py" "${CLI_ARGS[@]}"
