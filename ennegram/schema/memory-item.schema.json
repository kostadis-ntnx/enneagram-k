{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnnegramMemoryItem",
  "type": "object",
  "required": [
    "id",
    "source_uri",
    "source_anchor",
    "summary",
    "confidence",
    "last_validated_at",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source_uri": {
      "type": "string",
      "minLength": 1
    },
    "source_anchor": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "last_validated_at": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "stale",
        "conflicted",
        "deprecated"
      ]
    }
  },
  "additionalProperties": true
}
